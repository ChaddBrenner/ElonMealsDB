COMPOSE_PROJECT_NAME=elonmealsdb

# MySQL bootstrap credentials. Change every value before public self-hosting.
MYSQL_DATABASE=elon_meals
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_API_USER=elon_api
MYSQL_API_PASSWORD=change-me-api-readonly-password
MYSQL_SCRAPER_USER=elon_scraper
MYSQL_SCRAPER_PASSWORD=change-me-scraper-writer-password

# Backend runtime.
NODE_ENV=production
API_PORT=9000
DB_HOST=mysql
DB_PORT=3306
DB_NAME=elon_meals
DB_USER=elon_api
DB_PASSWORD=change-me-api-readonly-password
CORS_ORIGINS=http://localhost:8080
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
BODY_LIMIT=8kb

# Frontend runtime served by nginx. Use a relative URL behind the included proxy.
FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=8080
VITE_API_BASE_URL=

# Private scraper import scheduler. Times are America/New_York HH:MM values.
SCRAPER_RUN_TIMES=05:15,15:15
SCRAPER_DAYS_AHEAD=1
SCRAPER_RUN_ON_START=true
